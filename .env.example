# =========================================================================
# AI GOVERNANCE CONTROL TOWER — ENTERPRISE SAAS CONFIGURATION TEMPLATE
# =========================================================================
#
# Duplicate this file as '.env' in your local environment.
# Note: Client-exposed variables MUST be prefixed with 'VITE_'.
# Secrets MUST NEVER be checked into version control or exposed to the client.
#

# -------------------------------------------------------------------------
# 1. CORE EXECUTION MODE
# -------------------------------------------------------------------------
NODE_ENV=development
PORT=5173

# -------------------------------------------------------------------------
# 2. DATABASE PERSISTENCE CONFIGURATION
# -------------------------------------------------------------------------
# Supported modes:
# - 'localStorage': Zero-dependency browser-only storage (Default for public demos)
# - 'supabase-simulated': High-fidelity mock DB telemetry with active RLS logging
# - 'supabase-live': Real persistent database synchronization
VITE_DB_MODE=localStorage

# Supabase Client Connectivity (VITE_ variables can be exposed to browser)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key

# Supabase Server-Only Credentials (CRITICAL: Non-VITE variables are server-side only. NEVER expose to client!)
SUPABASE_SERVICE_ROLE_KEY=replace_with_server_side_supabase_service_role_key

# -------------------------------------------------------------------------
# 3. SECURE BACKEND-ONLY AI ENGINE & COPAILOT BRAIN
# -------------------------------------------------------------------------
# Supported AI execution modes (Evaluated strictly on the backend/serverless layer):
# - 'mock': Local high-fidelity, deterministic bilingual responses (No tokens cost, default)
# - 'live': Live serverless OpenAI completions via Vercel Routes & Supabase Edge Functions
# - 'disabled': AI endpoints completely deactivated returning a safe error fallback
AI_MODE=mock

# Centralized OpenAI Model selection
OPENAI_MODEL=gpt-4o

# OpenAI API Key (CRITICAL: Server-side only! NEVER prefix with VITE_ or expose to client)
OPENAI_API_KEY=replace_with_server_side_openai_key

# -------------------------------------------------------------------------
# 4. BILLING & SAAS SUBSCRIPTION METRICS
# -------------------------------------------------------------------------
# Supported modes:
# - 'mock': Local simulated enterprise subscriptions and quota gates (Default)
# - 'stripe-live': Production Stripe billing integration
VITE_BILLING_MODE=mock

# Stripe API Keys (Server-side only)
STRIPE_SECRET_KEY=replace_with_server_side_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# -------------------------------------------------------------------------
# 5. ENTERPRISE RATE LIMITING CONFIGURATION
# -------------------------------------------------------------------------
# Max permitted request counters inside the evaluation time windows
RATE_LIMIT_MAX_AI_RUNS_PER_ORG=5
RATE_LIMIT_WINDOW_MINUTES=60

